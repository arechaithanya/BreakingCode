# Judge0 API Configuration
# Get your free API key from RapidAPI: https://rapidapi.com/judge0-official/api/judge0-ce

# Judge0 API URL (CE = Community Edition, free tier available)
VITE_JUDGE0_API_URL=https://judge0-ce.p.rapidapi.com

# Your RapidAPI Key (required for Judge0 CE)
# Sign up at https://rapidapi.com and subscribe to Judge0 CE
VITE_JUDGE0_API_KEY=your_rapidapi_key_here

# RapidAPI Host (usually judge0-ce.p.rapidapi.com for CE)
VITE_JUDGE0_API_HOST=judge0-ce.p.rapidapi.com

# Alternative: Self-hosted Judge0 (no API key required)
# VITE_JUDGE0_API_URL=http://localhost:2358
# VITE_JUDGE0_API_KEY=
# VITE_JUDGE0_API_HOST=
